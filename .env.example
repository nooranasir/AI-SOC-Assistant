# General Settings
APP_NAME="AI SOC Assistant"
APP_VERSION=1.0.0
APP_ENV=development

# LLM Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Integrations and Enrichment
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Elasticsearch Integration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password_here
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here
ELASTICSEARCH_ALERTS_INDEX=alerts
ELASTICSEARCH_LOGS_INDEX=logs

# Paths
MITRE_MAPPING_PATH=data/mitre/mitre_mapping.json
